# ──────────────────────────────────────
# MongoDB (shared by user, rooms, review, notification services)
# ──────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# ──────────────────────────────────────
# JWT (used by auth-service and api-gateway)
# ──────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15m
REFRESH_SECRET=your-refresh-secret-here
REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────
# Internal service auth (api-gateway validates this from microservices)
# ──────────────────────────────────────
INTERNAL_SERVICE_KEY=your-internal-secret-here

# ──────────────────────────────────────
# API Gateway
# ──────────────────────────────────────
PORT=3400
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────────────
# PostgreSQL (booking-service)
# ──────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stayeasy_booking

# ──────────────────────────────────────
# Kafka
# ──────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKAJS_NO_PARTITIONER_WARNING=1

# ──────────────────────────────────────
# Email / SMTP (notification-service)
# ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# ──────────────────────────────────────
# gRPC Service Hosts (for docker-compose — auto-set to service names)
# For Azure deployment — set to internal FQDN via CI/CD pipeline
# ──────────────────────────────────────
AUTH_SERVICE_HOST=auth-service
AUTH_SERVICE_PORT=50050
USER_SERVICE_HOST=user-service
USER_SERVICE_PORT=50051
ROOMS_SERVICE_HOST=rooms-service
ROOMS_SERVICE_PORT=50052
BOOKING_SERVICE_HOST=booking-service
BOOKING_SERVICE_PORT=50053
REVIEW_SERVICE_HOST=review-service
REVIEW_SERVICE_PORT=50054
NOTIFICATION_SERVICE_HOST=notification-service
NOTIFICATION_SERVICE_PORT=50055
